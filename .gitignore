.DS_Store
*~
*.swp
*.swo
*.tmp
.~lock.*#

# Python/runtime caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local environments
.env
.venv/
venv/
env/

# Local work areas and scheduler/container logs
logs/
scratch/
work/
nipype_work/
code/work/
code/hpc_output/
.proc-*
*.log
*.out
nohup.out

# Large or generated imaging files
*.nii
*.nii.gz
*.bval
*.bvec
*.mat
*.html

# BIDS data generated by conversion. Keep project metadata and event/scans text
# files trackable when intentionally added.
bids/.heudiconv/
bids/**/*.nii
bids/**/*.nii.gz
!bids/participants.tsv
!bids/dataset_description.json
!bids/sub-*/ses-*/func/*_events.tsv
!bids/sub-*/ses-*/sub-*_scans.tsv

# Generated derivatives and reports. Scripts live in code/.
derivatives/**
!derivatives/
mriqc-metrics*.csv

# Generated metrics/manifests that previously appeared under code/
code/*metrics*.csv
code/*_metrics.tsv
code/flair_*.tsv
code/icv_*.csv
code/icv_*.png
code/mask_coverage*.csv
code/merged_masks_*/
