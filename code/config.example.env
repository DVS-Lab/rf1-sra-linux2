# Example local configuration for Smith Lab Linux2.
#
# Copy this file to code/config.env and edit values there for a local checkout.
# code/config.env is intentionally ignored by Git.

PROJECT_ROOT=/ZPOOL/data/projects/rf1-sra-linux2
SOURCEDATA_ROOT=/ZPOOL/data/sourcedata/sourcedata/rf1-sra
TOOLS_ROOT=/ZPOOL/data/tools
SCRATCH_ROOT=/ZPOOL/data/scratch
TEMPLATEFLOW_HOME=/ZPOOL/data/tools/templateflow
MPLCONFIGDIR_HOST=/ZPOOL/data/tools/mplconfigdir
LICENSES_DIR=/ZPOOL/data/tools/licenses

HEUDICONV_IMAGE=/ZPOOL/data/tools/heudiconv_1.3.3.sif
MRIQC_IMAGE=/ZPOOL/data/tools/mriqc-24.0.2.simg
FMRIPREP_IMAGE=/ZPOOL/data/tools/fmriprep-25.2.5.simg
WARPKIT_IMAGE=/ZPOOL/data/tools/warpkit.sif

# The code currently preserves the March 4, 2025 cutoff used by the script.
# Historical comments mention March 18, 2025; Jacob should confirm the intended
# value during Linux2 validation before changing this default.
SCANNER_UPGRADE_CUTOFF=2025-03-04
